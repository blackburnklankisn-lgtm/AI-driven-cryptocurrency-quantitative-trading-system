# ============================================================
# 安全规则：此文件为模板，不含真实密钥
# 复制本文件为 .env，填入真实值；.env 已在 .gitignore 中
# ============================================================

# ----------------------------
# 交易所 API 密钥 (实盘)
# ----------------------------
EXCHANGE_ID=binance
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

OKX_API_KEY=your_api_key_here
OKX_SECRET=your_secret_here
OKX_PASSPHRASE=your_passphrase_here

# ----------------------------
# 系统运行模式
# live | paper | backtest
# ----------------------------
TRADING_MODE=paper

# ----------------------------
# 数据库连接
# ----------------------------
DATABASE_URL=postgresql://trader:password@localhost:5432/crypto_quant
REDIS_URL=redis://localhost:6379/0

# ----------------------------
# 日志配置
# ----------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs

# ----------------------------
# 风控参数 (可在 configs/system.yaml 中覆盖)
# ----------------------------
MAX_PORTFOLIO_DRAWDOWN=0.10
MAX_DAILY_LOSS=0.03
MAX_POSITION_PCT=0.20
